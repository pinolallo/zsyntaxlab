# PostgreSQL + pgvector
# Option A: Supabase free tier (recommended — pgvector pre-installed)
#   Get connection string from: Project → Settings → Database → Connection string (URI)
# Option B: local Postgres with pgvector:
#   brew install postgresql@16 && brew services start postgresql@16
#   psql -c "CREATE DATABASE zsyntax;"
#   psql zsyntax -c "CREATE EXTENSION IF NOT EXISTS vector;"
DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

# UserHub auth (same pattern as GiroDeiBar)
USERHUB_URL="https://your-userhub-instance.com"
USERHUB_API_KEY=""

# iron-session cookie encryption — must be at least 32 characters
IRON_SESSION_SECRET="change-me-to-a-random-32-char-secret!!"

# Embeddings provider (OpenRouter does NOT expose /embeddings)
# Options: openai | voyage | ollama
EMBEDDING_PROVIDER="openai"
OPENAI_API_KEY=""       # for embeddings only (not LLM)
VOYAGE_API_KEY=""       # alternative: voyage-3 model
OLLAMA_URL="http://localhost:11434"  # alternative: nomic-embed-text

# AI model and search — also configurable via /admin panel (stored in DB)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"
BRAVE_KEY=""

# Local folder for downloaded PDFs
PDF_STORAGE_PATH="./papers"
